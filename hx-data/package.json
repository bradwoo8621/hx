{
	"name": "@hx/data",
	"version": "0.1.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bradwoo8621/hx.git",
		"directory": "hx-data"
	},
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/bradwoo8621/hx/issues"
	},
	"homepage": "https://github.com/bradwoo8621/hx/tree/main/hx-data",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/hx-data.esm.js",
			"types": "./dist/esm/index.d.ts"
		},
		"./*": {
			"import": "./dist/esm/*.js",
			"types": "./dist/esm/*.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"dts": "tsgo -p tsconfig.json --declaration --emitDeclarationOnly --noEmit false --rootDir src --outDir dist/esm",
		"build": "vp build",
		"lint": "eslint .",
		"test": "vp test --run",
		"test:watch": "vp test"
	},
	"devDependencies": {
		"@eslint/js": "catalog:",
		"@types/node": "catalog:",
		"@typescript/native-preview": "catalog:",
		"eslint": "catalog:",
		"globals": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"packageManager": "pnpm@11.5.2",
	"engines": {
		"pnpm": "11.5.2",
		"node": ">=22.18.0"
	}
}
