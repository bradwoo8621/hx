{
	"name": "@hx/monorepo",
	"version": "0.1.0",
	"packageManager": "pnpm@11.5.2",
	"engines": {
		"pnpm": "11.5.2",
		"node": ">=22.18.0"
	},
	"scripts": {
		"build:data": "cd hx-data && vp build",
		"test:data": "cd hx-data && vp test",
		"build:components": "cd hx-components && vp build",
		"storybook:components": "cd hx-components && pnpm run storybook",
		"test:components": "cd hx-components && vp test",
		"build:all": "pnpm run build:data && pnpm run build:components"
	},
	"devDependencies": {
		"vite-plus": "catalog:"
	}
}
