{
	"name": "@hx/monorepo",
	"version": "0.1.0",
	"packageManager": "pnpm@11.5.2",
	"engines": {
		"pnpm": "11.5.2",
		"node": ">=22.18.0"
	},
	"scripts": {
		"build:data": "vp run --filter @hx/data build",
		"test:data": "vp run --filter @hx/data test",
		"build:components": "vp run --filter @hx/components build",
		"storybook:components": "vp run --filter @hx/components storybook",
		"test:components": "vp run --filter @hx/components test",
		"build:all": "vp run build:data && vp run build:components"
	},
	"devDependencies": {
		"vite-plus": "catalog:"
	}
}
